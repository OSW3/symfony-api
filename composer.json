{
    "name": "osw3/symfony-api",
    "description": "OSW3 API Bundle",
	"type": "symfony-bundle",
	"authors": [
		{
			"name": "Project Contributors",
			"homepage": "https://github.com/OSW3/symfony-api/graphs/contributors"
		}
	],
	"license": "proprietary",
	"minimum-stability": "dev",
	"prefer-stable": true,
    "autoload": {
        "psr-4": {
            "OSW3\\SymfonyApi\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "doctrine/doctrine-bundle": "*",
        "doctrine/doctrine-migrations-bundle": "*",
        "doctrine/orm": "*",
        "phpdocumentor/reflection-docblock": "*",
        "phpstan/phpdoc-parser": "*",
        "symfony/property-access": "*",
        "symfony/property-info": "*",
		"symfony/security-bundle": "*",
        "symfony/serializer": "*"
    }
}
